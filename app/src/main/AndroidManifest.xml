<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <uses-permission android:name="android.permission.SCHEDULE_EXACT_ALARM" />
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />
    <uses-permission android:name="android.permission.ACTIVITY_RECOGNITION" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_HEALTH" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_CONNECTED_DEVICE" />
    <uses-permission android:name="android.permission.BLUETOOTH" android:maxSdkVersion="30" />
    <uses-permission android:name="android.permission.BLUETOOTH_ADMIN" android:maxSdkVersion="30" />
    <uses-permission android:name="android.permission.BLUETOOTH_CONNECT" />
    <uses-permission android:name="android.permission.health.READ_STEPS" />

    <queries>
        <package android:name="com.google.android.apps.healthdata" />
    </queries>

    <application
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.CoolW">
        
        <activity
            android:name=".MainActivity"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <activity
            android:name=".FinanceActivity"
            android:exported="false" />

        <activity-alias
            android:name="ViewPermissionUsageActivity"
            android:exported="true"
            android:targetActivity=".MainActivity"
            android:permission="android.permission.START_VIEW_PERMISSION_USAGE">
            <intent-filter>
                <action android:name="android.intent.action.VIEW_PERMISSION_USAGE" />
                <category android:name="android.intent.category.HEALTH_PERMISSIONS" />
            </intent-filter>
        </activity-alias>

        <!-- Widgets -->
        <receiver
            android:name=".NothingClockWidget"
            android:label="@string/widget_name_clock"
            android:exported="true">
            <intent-filter>
                <action android:name="android.appwidget.action.APPWIDGET_UPDATE" />
                <action android:name="com.kythonlk.coolw.ACTION_TICK" />
                <action android:name="com.kythonlk.coolw.UPDATE_ALL_WIDGETS" />
                <action android:name="android.intent.action.TIME_SET" />
                <action android:name="android.intent.action.TIMEZONE_CHANGED" />
            </intent-filter>
            <meta-data
                android:name="android.appwidget.provider"
                android:resource="@xml/nothing_clock_widget_info" />
        </receiver>

        <receiver
            android:name=".NothingStepsWidget"
            android:label="@string/widget_name_steps"
            android:exported="true">
            <intent-filter>
                <action android:name="android.appwidget.action.APPWIDGET_UPDATE" />
                <action android:name="com.kythonlk.coolw.ACTION_STEP_UPDATE" />
                <action android:name="com.kythonlk.coolw.UPDATE_ALL_WIDGETS" />
            </intent-filter>
            <meta-data
                android:name="android.appwidget.provider"
                android:resource="@xml/nothing_steps_widget_info" />
        </receiver>

        <receiver
            android:name=".NothingMusicWidget"
            android:label="@string/widget_name_music"
            android:exported="true">
            <intent-filter>
                <action android:name="android.appwidget.action.APPWIDGET_UPDATE" />
                <action android:name="com.kythonlk.coolw.ACTION_PLAY_PAUSE" />
                <action android:name="com.kythonlk.coolw.ACTION_NEXT" />
                <action android:name="com.kythonlk.coolw.ACTION_PREV" />
                <action android:name="com.kythonlk.coolw.ACTION_MUSIC_UPDATE" />
                <action android:name="com.kythonlk.coolw.UPDATE_ALL_WIDGETS" />
            </intent-filter>
            <meta-data
                android:name="android.appwidget.provider"
                android:resource="@xml/nothing_music_widget_info" />
        </receiver>

        <receiver
            android:name=".NothingHeadphonesWidget"
            android:label="@string/widget_name_headphones"
            android:exported="true">
            <intent-filter>
                <action android:name="android.appwidget.action.APPWIDGET_UPDATE" />
                <action android:name="com.kythonlk.coolw.ACTION_HEADPHONE_UPDATE" />
                <action android:name="com.kythonlk.coolw.UPDATE_ALL_WIDGETS" />
            </intent-filter>
            <meta-data
                android:name="android.appwidget.provider"
                android:resource="@xml/nothing_headphones_widget_info" />
        </receiver>

        <receiver
            android:name=".NothingDateWidget"
            android:label="@string/widget_name_date"
            android:exported="true">
            <intent-filter>
                <action android:name="android.appwidget.action.APPWIDGET_UPDATE" />
                <action android:name="com.kythonlk.coolw.ACTION_DATE_TICK" />
                <action android:name="com.kythonlk.coolw.UPDATE_ALL_WIDGETS" />
                <action android:name="android.intent.action.DATE_CHANGED" />
                <action android:name="android.intent.action.TIMEZONE_CHANGED" />
            </intent-filter>
            <meta-data
                android:name="android.appwidget.provider"
                android:resource="@xml/nothing_date_widget_info" />
        </receiver>

        <receiver
            android:name=".NothingFinanceWidget"
            android:label="@string/widget_name_finance"
            android:exported="true">
            <intent-filter>
                <action android:name="android.appwidget.action.APPWIDGET_UPDATE" />
                <action android:name="com.kythonlk.coolw.ACTION_FINANCE_UPDATE" />
                <action android:name="com.kythonlk.coolw.UPDATE_ALL_WIDGETS" />
            </intent-filter>
            <meta-data
                android:name="android.appwidget.provider"
                android:resource="@xml/nothing_finance_widget_info" />
        </receiver>

        <receiver
            android:name=".NothingTodoWidget"
            android:label="@string/widget_name_todo"
            android:exported="true">
            <intent-filter>
                <action android:name="android.appwidget.action.APPWIDGET_UPDATE" />
                <action android:name="com.kythonlk.coolw.ACTION_TODO_WIDGET_UPDATE" />
                <action android:name="com.kythonlk.coolw.UPDATE_ALL_WIDGETS" />
            </intent-filter>
            <meta-data
                android:name="android.appwidget.provider"
                android:resource="@xml/nothing_todo_widget_info" />
        </receiver>

        <!-- Alarm Receiver -->
        <receiver
            android:name=".AlarmReceiver"
            android:exported="false" />

        <!-- Notification Listener Service -->
        <service
            android:name=".MediaNotificationListener"
            android:label="CoolW Media Sync"
            android:permission="android.permission.BIND_NOTIFICATION_LISTENER_SERVICE"
            android:exported="true">
            <intent-filter>
                <action android:name="android.service.notification.NotificationListenerService" />
            </intent-filter>
        </service>

        <service
            android:name=".StepCounterService"
            android:exported="false"
            android:foregroundServiceType="health" />

        <service
            android:name=".BluetoothHeadphoneService"
            android:exported="false"
            android:foregroundServiceType="connectedDevice" />

    </application>

</manifest>

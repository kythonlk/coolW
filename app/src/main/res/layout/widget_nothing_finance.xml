<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/finance_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/nothing_widget_background"
    android:padding="0dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:gravity="center">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="4dp">

            <ImageView
                android:layout_width="6dp"
                android:layout_height="6dp"
                android:src="@drawable/nothing_red_dot"
                android:layout_marginEnd="6dp"
                android:contentDescription="@null" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="BALANCE THIS MONTH"
                android:textColor="@color/nothing_text_secondary"
                android:textSize="9sp"
                android:fontFamily="sans-serif-black"
                android:letterSpacing="0.1" />
        </LinearLayout>

        <TextView
            android:id="@+id/finance_balance"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="0.00"
            android:textColor="@color/nothing_text_primary"
            android:textSize="24sp"
            android:fontFamily="monospace"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/finance_breakdown"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="+0.00  ·  -0.00"
            android:textColor="@color/nothing_text_tertiary"
            android:textSize="10sp"
            android:layout_marginTop="2dp"
            android:fontFamily="monospace" />

    </LinearLayout>
</RelativeLayout>

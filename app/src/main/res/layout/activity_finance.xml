<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#050505"
    android:fillViewport="true"
    android:fitsSystemWindows="true"
    tools:context=".FinanceActivity">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="12dp">

        <!-- HEADER -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="20dp">

            <TextView
                android:id="@+id/btn_back"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="‹"
                android:textColor="@color/nothing_text_primary"
                android:textSize="26sp"
                android:padding="4dp"
                android:clickable="true"
                android:focusable="true"
                android:background="?android:attr/selectableItemBackgroundBorderless" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="FINANCE"
                android:textColor="@color/nothing_text_primary"
                android:textSize="18sp"
                android:fontFamily="sans-serif-black"
                android:letterSpacing="0.1"
                android:layout_marginStart="4dp" />

            <View
                android:layout_width="0dp"
                android:layout_height="1dp"
                android:layout_weight="1" />

            <ImageView
                android:layout_width="8dp"
                android:layout_height="8dp"
                android:src="@drawable/nothing_red_dot"
                android:contentDescription="@null" />
        </LinearLayout>

        <!-- MONTH SELECTOR -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="12dp">

            <TextView
                android:id="@+id/btn_prev_month"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="‹"
                android:textColor="@color/nothing_text_secondary"
                android:textSize="20sp"
                android:padding="8dp"
                android:clickable="true"
                android:focusable="true"
                android:background="?android:attr/selectableItemBackgroundBorderless" />

            <TextView
                android:id="@+id/tv_month_label"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="center"
                android:text="JUL 2026"
                android:textColor="@color/nothing_text_primary"
                android:textSize="13sp"
                android:fontFamily="sans-serif-black"
                android:letterSpacing="0.15" />

            <TextView
                android:id="@+id/btn_next_month"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="›"
                android:textColor="@color/nothing_text_secondary"
                android:textSize="20sp"
                android:padding="8dp"
                android:clickable="true"
                android:focusable="true"
                android:background="?android:attr/selectableItemBackgroundBorderless" />
        </LinearLayout>

        <!-- BALANCE CARD -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            android:background="@drawable/nothing_widget_background"
            android:padding="20dp"
            android:layout_marginBottom="12dp">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="10dp">

                <ImageView
                    android:layout_width="6dp"
                    android:layout_height="6dp"
                    android:src="@drawable/nothing_red_dot"
                    android:layout_marginEnd="6dp"
                    android:contentDescription="@null" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="BALANCE"
                    android:textColor="@color/nothing_text_secondary"
                    android:textSize="10sp"
                    android:fontFamily="sans-serif-black"
                    android:letterSpacing="0.15" />
            </LinearLayout>

            <TextView
                android:id="@+id/tv_balance"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0.00"
                android:textColor="@color/nothing_text_primary"
                android:textSize="40sp"
                android:fontFamily="monospace"
                android:textStyle="bold" />

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="14dp">

                <TextView
                    android:id="@+id/tv_income_total"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="+0.00"
                    android:textColor="@color/nothing_text_primary"
                    android:textSize="13sp"
                    android:fontFamily="sans-serif-medium" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="   ·   "
                    android:textColor="@color/nothing_text_tertiary"
                    android:textSize="13sp" />

                <TextView
                    android:id="@+id/tv_expense_total"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="-0.00"
                    android:textColor="@color/nothing_red"
                    android:textSize="13sp"
                    android:fontFamily="sans-serif-medium" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="18dp">

                <Button
                    android:id="@+id/btn_add_income"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="+ INCOME"
                    android:textColor="#000000"
                    android:backgroundTint="@color/nothing_text_primary"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:layout_marginEnd="8dp"
                    app:cornerRadius="8dp" />

                <Button
                    android:id="@+id/btn_add_expense"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="− EXPENSE"
                    android:textColor="@color/nothing_text_primary"
                    android:backgroundTint="@color/nothing_red"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    app:cornerRadius="8dp" />
            </LinearLayout>
        </LinearLayout>

        <!-- CATEGORY BREAKDOWN CHART -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/nothing_widget_background"
            android:padding="16dp"
            android:layout_marginBottom="12dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="SPENDING BY CATEGORY"
                android:textColor="@color/nothing_text_primary"
                android:textSize="13sp"
                android:fontFamily="sans-serif-medium"
                android:letterSpacing="0.1"
                android:layout_marginBottom="10dp" />

            <com.kythonlk.coolw.CategoryBarChartView
                android:id="@+id/chart_category"
                android:layout_width="match_parent"
                android:layout_height="wrap_content" />

        </LinearLayout>

        <!-- TRANSACTIONS -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/nothing_widget_background"
            android:padding="12dp"
            android:layout_marginBottom="16dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="8dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="TRANSACTIONS"
                    android:textColor="@color/nothing_text_primary"
                    android:textSize="13sp"
                    android:fontFamily="sans-serif-medium"
                    android:letterSpacing="0.1" />

                <TextView
                    android:id="@+id/btn_export_json"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="EXPORT JSON"
                    android:textColor="@color/nothing_red"
                    android:textSize="10sp"
                    android:fontFamily="sans-serif-black"
                    android:letterSpacing="0.05"
                    android:padding="6dp"
                    android:clickable="true"
                    android:focusable="true"
                    android:background="?android:attr/selectableItemBackgroundBorderless" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/transaction_list_container"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical" />

        </LinearLayout>

    </LinearLayout>
</ScrollView>

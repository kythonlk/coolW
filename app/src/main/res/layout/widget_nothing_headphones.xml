<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/nothing_widget_background"
    android:padding="16dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:gravity="center">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="8dp">

            <ImageView
                android:layout_width="5dp"
                android:layout_height="5dp"
                android:src="@drawable/nothing_red_dot"
                android:layout_marginEnd="6dp"
                android:contentDescription="Red Dot" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="HEADPHONES"
                android:textColor="#88FFFFFF"
                android:textSize="9sp"
                android:fontFamily="sans-serif-black"
                android:letterSpacing="0.2" />
        </LinearLayout>

        <ImageView
            android:id="@+id/headphone_icon"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:src="@drawable/ic_headphones"
            android:contentDescription="Headphones" />

        <TextView
            android:id="@+id/headphone_name"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="WIWU"
            android:textColor="#FFFFFFFF"
            android:textSize="13sp"
            android:textStyle="bold"
            android:singleLine="true"
            android:ellipsize="end"
            android:gravity="center"
            android:layout_marginTop="6dp"
            android:fontFamily="sans-serif-medium" />

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginTop="10dp">

            <ImageView
                android:id="@+id/headphone_battery_ring"
                android:layout_width="52dp"
                android:layout_height="52dp"
                android:layout_marginEnd="10dp"
                android:contentDescription="Battery Level" />

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/headphone_battery_text"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="85%"
                    android:textColor="#FFFFFF"
                    android:textSize="14sp"
                    android:fontFamily="sans-serif-medium" />

                <TextView
                    android:id="@+id/headphone_mode"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="ANC"
                    android:textColor="#88FFFFFF"
                    android:textSize="10sp"
                    android:layout_marginTop="2dp"
                    android:fontFamily="sans-serif-medium"
                    android:letterSpacing="0.1" />
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>
</RelativeLayout>

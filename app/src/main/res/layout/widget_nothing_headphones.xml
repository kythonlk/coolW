<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/nothing_widget_background"
    android:padding="4dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:gravity="center">

        <ImageView
            android:id="@+id/headphone_icon"
            android:layout_width="64dp"
            android:layout_height="64dp"
            android:src="@drawable/ic_headphones"
            android:contentDescription="Headphones"
            android:alpha="0.9" />

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center"
            android:layout_marginTop="8dp">

            <TextView
                android:id="@+id/headphone_battery_text"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="85%"
                android:textColor="#FFFFFF"
                android:textSize="12sp"
                android:fontFamily="sans-serif-medium" />

            <ImageView
                android:id="@+id/battery_divider"
                android:layout_width="1dp"
                android:layout_height="10dp"
                android:src="@android:color/white"
                android:alpha="0.2"
                android:layout_marginHorizontal="8dp"
                android:visibility="gone"
                android:contentDescription="@null" />

            <TextView
                android:id="@+id/headphone_mode"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="ANC"
                android:textColor="#FF3B30"
                android:textSize="10sp"
                android:fontFamily="sans-serif-black"
                android:letterSpacing="0.1" />
        </LinearLayout>
    </LinearLayout>
</RelativeLayout>

<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="#121212"
    android:padding="16dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginBottom="14dp">

        <TextView
            android:id="@+id/dialog_toggle_income"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="INCOME"
            android:textAlignment="center"
            android:textColor="#FFFFFF"
            android:textSize="12sp"
            android:textStyle="bold"
            android:padding="10dp"
            android:background="#FFFFFF"
            android:layout_marginEnd="4dp"
            android:clickable="true"
            android:focusable="true" />

        <TextView
            android:id="@+id/dialog_toggle_expense"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="EXPENSE"
            android:textAlignment="center"
            android:textColor="#88FFFFFF"
            android:textSize="12sp"
            android:textStyle="bold"
            android:padding="10dp"
            android:background="#1AFFFFFF"
            android:clickable="true"
            android:focusable="true" />
    </LinearLayout>

    <EditText
        android:id="@+id/dialog_et_amount"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Amount"
        android:textColorHint="#55FFFFFF"
        android:textColor="#FFFFFF"
        android:backgroundTint="#FFFFFF"
        android:textSize="20sp"
        android:inputType="numberDecimal"
        android:layout_marginBottom="12dp"
        android:importantForAutofill="no" />

    <Spinner
        android:id="@+id/dialog_spinner_category"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="12dp"
        android:background="#15FFFFFF"
        android:padding="8dp"
        android:popupBackground="#1C1C1C" />

    <EditText
        android:id="@+id/dialog_et_note"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Note (optional)"
        android:textColorHint="#55FFFFFF"
        android:textColor="#FFFFFF"
        android:backgroundTint="#FFFFFF"
        android:textSize="14sp"
        android:inputType="textCapSentences"
        android:layout_marginBottom="16dp"
        android:importantForAutofill="no" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <TextView
            android:id="@+id/dialog_tv_selected_time"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="2026-07-01 12:00"
            android:textColor="#FFFFFF"
            android:textSize="14sp"
            android:fontFamily="monospace" />

        <TextView
            android:id="@+id/dialog_btn_select_time"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="SET DATE"
            android:textColor="#FF3B30"
            android:textSize="12sp"
            android:textStyle="bold"
            android:padding="8dp"
            android:clickable="true"
            android:focusable="true" />
    </LinearLayout>

</LinearLayout>
